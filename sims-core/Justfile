# SIMS Core test recipes

# Run 4D medium instance tests with pseudo-solver, nd-tree archive only
test:
    uv run pytest \
        "tests/test_two_phases_instances.py::TestTwoPhaseInstances::test_solve_two_phase_4d_on_medium_instances" \
        --use-pseudo-solver \
        --name "medium_instances" \
        -k "nd-tree" \
        -v -s \
        --log-cli-level=INFO

# Collect (but do not run) the same tests to verify parametrization
collect:
    uv run pytest \
        "tests/test_two_phases_instances.py::TestTwoPhaseInstances::test_solve_two_phase_4d_on_medium_instances" \
        --use-pseudo-solver \
        -k "nd-tree" \
        --collect-only
